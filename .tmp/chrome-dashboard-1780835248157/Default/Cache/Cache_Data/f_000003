      if (!text) return;
      const clipped = cell.scrollWidth > cell.clientWidth + 1 || [...cell.children].some((child) => child.scrollWidth > child.clientWidth + 1);
      if (clipped) {
        if (!cell.title) cell.dataset.autoTitle = "1";
