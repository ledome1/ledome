function financeUnique(values) {
  const seen = new Set();
  return values.map((value) => String(value || "").trim()).filter(Boolean).filter((value) => {
    const key = value.toLocaleLowerCase("vi");
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

function financeArray(values) {
