      handle.setPointerCapture(event.pointerId);
      table.classList.add("column-resizing");
    };
    handle.onpointermove = (event) => {
      if (!drag) return;
      const nextWidth = Math.max(56, drag.startWidth + event.clientX - drag.startX);
