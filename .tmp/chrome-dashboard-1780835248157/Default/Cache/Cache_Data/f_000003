      return;
    }
    const nextCode = data.currentCode || `${config.code}${String(config.rows.length + 1).padStart(3, "0")}`;
    const index = config.rows.findIndex((item) => item[0] === data.currentCode);
    const previous = index >= 0 ? config.rows[index] : [];
