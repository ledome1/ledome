.diary-smart .diary-calendar>i>small{display:grid;place-items:center;width:24px;height:24px;margin-left:auto;color:#60777d}
.diary-smart .diary-calendar>i.outside{background:#f7f9fa}
.diary-smart .diary-calendar>i.outside>small{color:#b0babc}
.diary-smart .diary-calendar>i.today{background:#fbfefd;outline:0}
