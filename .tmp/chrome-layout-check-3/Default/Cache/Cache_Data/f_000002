/* ================================================================
   DEBT DASHBOARD — Premium Redesign Overrides
   (these cascade after the base debt styles above)
   ================================================================ */

/* Container & background */
.debt-dashboard-container {
  padding: 20px 22px;
  background: #f3f8fa;
  min-height: calc(100vh - 120px);
  font-family: Inter, 'Segoe UI', Arial, sans-serif;
}

/* Header card */
.debt-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
  padding: 16px 20px;
  background: #fff;
  border: 1px solid #d8e8ea;
  border-radius: 8px;
  box-shadow: 0 1px 4px rgba(22,55,65,.05);
}

.debt-header-row h2 {
  font-size: 18px;
  font-weight: 800;
  color: #12333c;
  margin: 0 0 3px;
  letter-spacing: -.2px;
}

.debt-subtitle {
  font-size: 12px;
  color: #7a9299;
  margin: 0;
  line-height: 1.4;
}

.debt-header-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

/* Buttons */
.debt-btn {
  height: 34px;
  padding: 0 14px;
  font-size: 12px;
  font-weight: 600;
  border-radius: 5px;
  border: 1px solid #c8d8db;
  background: #fff;
  color: #3e6069;
  cursor: pointer;
  transition: background .14s, border-color .14s;
  font-family: inherit;
  white-space: nowrap;
}
.debt-btn:hover { background: #eef6f7; border-color: #9bbdc4; }
.debt-btn.green { background: #168f87; color: #fff; border-color: #168f87; }
.debt-btn.green:hover { background: #107c75; border-color: #0e6c66; }

/* Layout */
.debt-layout-grid {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 18px;
  align-items: start;
  margin-top: 0;
}
@media (max-width: 1100px) { .debt-layout-grid { grid-template-columns: 1fr; } }

.debt-main-content { min-width: 0; }
.debt-side-panel { position: sticky; top: 16px; }

/* Table card */
.debt-table-wrapper {
  background: #fff;
  border: 1px solid #d0e2e5;
  border-radius: 8px;
  box-shadow: 0 2px 10px rgba(22,55,65,.05);
  overflow: hidden;
}

.debt-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
  font-family: inherit;
  text-align: left;
}

.debt-table th {
  background: #f5f9fa;
  color: #4f7079;
  font-weight: 700;
  font-size: 11px;
  padding: 11px 14px;
  border-bottom: 2px solid #d4e4e7;
  white-space: nowrap;
  text-transform: uppercase;
  letter-spacing: .03em;
}

.debt-table td {
  padding: 12px 14px;
  border-bottom: 1px solid #eaf1f3;
  color: #2c4f58;
  vertical-align: middle;
  font-size: 12px;
  line-height: 1.45;
}

.debt-table tbody tr:last-child td { border-bottom: 0; }
.debt-table tbody tr:hover { background: #f8fcfc; }
.debt-table td.num { font-weight: 700; color: #1a3038; font-variant-numeric: tabular-nums; }

/* Empty/loading states */
.debt-loading, .debt-empty, .debt-error {
  text-align: center;
  padding: 44px 16px !important;
  color: #8fadb4;
  font-style: normal;
  font-size: 13px;
}
.debt-error { color: #c24040; }

/* Status badges */
.debt-badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 9px;
  border-radius: 20px;
  font-size: 10px;
  font-weight: 700;
  white-space: nowrap;
  letter-spacing: .02em;
}
.debt-badge.green { background: #e0f5eb; color: #177444; }
.debt-badge.blue  { background: #deeffe; color: #1560c8; }
.debt-badge.red   { background: #fee5e5; color: #bc3030; }

/* File cell */
.debt-attached-file {
  display: flex;
  align-items: center;
  gap: 6px;
  background: #edf7f5;
  border: 1px solid #b8dcd8;
  border-radius: 5px;
  padding: 4px 8px;
  max-width: 210px;
}
.debt-attached-file a {
  color: #168f87;
  text-decoration: none;
  font-size: 11px;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.debt-attached-file a:hover { text-decoration: underline; }
.debt-file-remove {
  background: transparent;
  border: 0;
  color: #8dadb3;
  font-size: 15px;
  cursor: pointer;
  padding: 0;
  line-height: 1;
  flex-shrink: 0;
}
.debt-file-remove:hover { color: #bc3030; }

.debt-upload-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  height: 28px;
  padding: 0 10px;
  font-size: 11px;
  font-weight: 600;
  border: 1px dashed #1aaa9f;
  background: transparent;
  color: #168f87;
  border-radius: 4px;
  cursor: pointer;
  font-family: inherit;
  transition: background .14s;
}
.debt-upload-btn:hover { background: #e5f7f5; }

/* Row actions */
.debt-actions { display: flex; gap: 6px; }
.debt-actions button {
  height: 26px;
  padding: 0 8px;
  font-size: 11px;
  font-weight: 600;
  border: 1px solid #c8d8dc;
  background: #fff;
  border-radius: 4px;
  cursor: pointer;
  color: #4f7079;
  font-family: inherit;
  transition: background .12s, border-color .12s;
}
.debt-actions button:hover { background: #eef6f8; border-color: #96b8c0; }
.debt-actions .debt-action-delete { color: #b03e3e; border-color: #f0cccc; background: #fff9f9; }
.debt-actions .debt-action-delete:hover { background: #fee5e5; border-color: #e89898; }

/* Confirm button */
.debt-confirm-btn {
  height: 28px;
  padding: 0 12px;
  font-size: 11px;
  font-weight: 700;
  border-radius: 5px;
  cursor: pointer;
  border: 1px solid transparent;
  font-family: inherit;
  transition: background .14s, transform .1s;
}
.debt-confirm-btn.active { background: #168f87; color: #fff; border-color: #168f87; }
.debt-confirm-btn.active:hover { background: #107c75; transform: translateY(-1px); }
.debt-confirm-btn.locked {
  background: #eff5f6;
  color: #8dadb3;
  border-color: #ccdde0;
  cursor: default;
}

/* Locked row */
.locked-row { background: #fafcfd; }
.locked-row td { color: #7a9299 !important; }

/* ---- Side summary panel ---- */
.debt-summary-panel {
  border-radius: 8px;
  overflow: hidden;
  padding: 0;
  box-shadow: 0 3px 14px rgba(22,55,65,.08);
  background: #fff;
}

.debt-summary-panel > h3 {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 13px 20px;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
}

/* Owner: teal */
.debt-summary-panel.owner { border: 1px solid #b2dfda; }
.debt-summary-panel.owner > h3 { background: #1aaa9f; color: #fff; }

/* Vendor: red */
.debt-summary-panel.vendor { border: 1px solid #f2bcbc; }
.debt-summary-panel.vendor > h3 { background: #c84343; color: #fff; }

/* Supplier: amber */
.debt-summary-panel.supplier { border: 1px solid #ecd5a8; }
.debt-summary-panel.supplier > h3 { background: #c07a10; color: #fff; }

.debt-summary-rows { display: flex; flex-direction: column; }

.debt-summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 18px;
  border-bottom: 1px solid #edf2f4;
}
.debt-summary-panel .debt-summary-row:last-child { border-bottom: 0; }

.debt-summary-row span { font-size: 12px; color: #557078; font-weight: 500; }
.debt-summary-row b   { font-size: 12px; color: #1a2e34; font-weight: 700; font-variant-numeric: tabular-nums; }

/* Balance row */
.balance-row {
  padding: 13px 18px !important;
  border-bottom: 0 !important;
}
.debt-summary-panel.owner .balance-row    { background: #f2fbfa; border-top: 2px solid #b2dfda !important; }
.debt-summary-panel.vendor .balance-row   { background: #fdf6f6; border-top: 2px solid #f0c0c0 !important; }
.debt-summary-panel.supplier .balance-row { background: #fdf9f3; border-top: 2px solid #ecdb9c !important; }

.balance-row span { font-size: 13px !important; font-weight: 800 !important; color: #12292f !important; }
.balance-row b    { font-size: 16px !important; font-weight: 800 !important; }
.debt-summary-panel.owner .balance-val    { color: #118f87; }
.debt-summary-panel.vendor .balance-val   { color: #c03535; }
.debt-summary-panel.supplier .balance-val { color: #b06a08; }

/* Responsive header */
@media (max-width: 700px) {
  .debt-header-row { flex-direction: column; align-items: flex-start; gap: 12px; }
  .debt-header-actions { width: 100%; }
  .debt-btn { flex: 1; }
}

/* ================================================================
   GLOBAL FONT FIX — ensure Inter loads everywhere
   ================================================================ */
body, button, input, select, textarea {
  font-family: 'Inter', 'Segoe UI', system-ui, Arial, sans-serif;
}

/* ================================================================
   PROJECT STAGE TRACKER — Complete Redesign
   ================================================================ */

/* Container wrapper */
.project-info-inline .project-stage-control {
  margin-top: 16px;
  padding: 18px 20px;
  border: 1px solid #d4e5e7;
  border-radius: 10px;
  background: #f8fbfc;
}

.project-info-inline .project-stage-control > header {
  align-items: center;
  margin: 0 0 14px;
  padding: 0 0 12px;
  border-bottom: 1px solid #d4e5e7;
}

.project-info-inline .project-stage-control h3 {
  margin: 0;
  color: #0e3540;
  font-size: 14px;
  font-weight: 700;
}

.project-info-inline .project-stage-control p {
  margin: 2px 0 0;
  font-size: 11px;
  color: #6e8b93;
}

/* The track grid */
.project-info-inline .project-stage-track {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(148px, 1fr));
  grid-auto-flow: row;
  grid-auto-columns: auto;
  gap: 8px;
  overflow: visible;
  padding: 0;
}

/* Hide decorative line */
.project-info-inline .project-stage-track:before,
.project-info-inline .project-stage-track:after { display: none; }

/* Each stage button */
.project-info-inline .project-stage-track button {
  display: grid;
  grid-template-columns: 36px 1fr;
  grid-template-rows: auto auto;
  align-items: center;
  gap: 3px 10px;
  min-height: 58px;
  padding: 10px 12px;
  background: #fff;
  border: 1px solid #d8e8ea;
  border-radius: 8px;
  text-align: left;
  transition: border-color .15s, box-shadow .15s, background .15s;
  cursor: pointer;
}

.project-info-inline .project-stage-track button:before { display: none; }

/* Number badge */
.project-info-inline .project-stage-track button b {
  display: flex;
  grid-row: 1 / 3;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #e8f3f5;
  color: #4e8a93;
  font-size: 13px;
  font-weight: 700;
  flex-shrink: 0;
  line-height: 1;
}

/* Stage name */
.project-info-inline .project-stage-track button span {
  min-width: 0;
  color: #2a4e58;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.3;
  word-break: break-word;
  white-space: normal;
}

/* Description (shown only on active) */
.project-info-inline .project-stage-track button small {
  display: none;
  grid-column: 2;
  color: #5a8896;
  font-size: 10px;
  line-height: 1.35;
  font-weight: 400;
}

/* --- Done state --- */
.project-info-inline .project-stage-track button.done {
  background: #f2fbf9;
  border-color: #b8e2da;
}
.project-info-inline .project-stage-track button.done b {
  background: #1aaa9f;
  color: #fff;
}
.project-info-inline .project-stage-track button.done span {
  color: #1a5c52;
}

/* --- Active state --- */
.project-info-inline .project-stage-track button.active {
  background: #e5f8f6;
  border-color: #1aaa9f;
  border-width: 2px;
  box-shadow: 0 0 0 3px rgba(26,170,159,.12);
}
.project-info-inline .project-stage-track button.active b {
  background: #fff;
  color: #0f8078;
  box-shadow: inset 0 0 0 2px #1aaa9f;
  font-size: 14px;
  font-weight: 800;
}
.project-info-inline .project-stage-track button.active span {
  color: #0a4840;
  font-weight: 700;
  font-size: 12px;
}
.project-info-inline .project-stage-track button.active small {
  display: none;
}

/* --- Upcoming state --- */
.project-info-inline .project-stage-track button.upcoming {
  opacity: .6;
}
.project-info-inline .project-stage-track button.upcoming b {
  background: #f0f4f5;
  color: #8aacb3;
}

/* Hover effect (non-disabled) */
.project-info-inline.editing .project-stage-track button:hover:not(.active) {
  border-color: #1aaa9f;
  background: #f0fbf9;
  box-shadow: 0 0 0 2px rgba(26,170,159,.10);
}

/* Responsive */
@media (max-width: 1100px) {
  .project-info-inline .project-stage-track {
    grid-template-columns: repeat(auto-fill, minmax(136px, 1fr));
  }
}
@media (max-width: 750px) {
  .project-info-inline .project-stage-track {
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 7px;
  }
  .project-info-inline .project-stage-track button {
    grid-template-columns: 28px 1fr;
    min-height: 50px;
    padding: 8px 10px;
    gap: 2px 8px;
  }
  .project-info-inline .project-stage-track button b {
    width: 26px;
    height: 26px;
    font-size: 11px;
  }
  .project-info-inline .project-stage-track button span {
    font-size: 11px;
  }
}

