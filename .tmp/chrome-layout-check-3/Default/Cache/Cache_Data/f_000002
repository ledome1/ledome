/* Keep the project dashboard sidebar identical to the main dashboard sidebar. */
:root {
  --app-font: Inter, "Segoe UI", system-ui, Arial, sans-serif;
  --app-font-size: 13px;
  --app-small-font-size: 11px;
  --sidebar-group-font-size: 13px;
  --sidebar-item-font-size: 12px;
}
body,
button,
input,
select,
textarea {
  font-family: var(--app-font);
  letter-spacing: 0;
}
body {
  font-size: var(--app-font-size);
  line-height: 1.4;
}
body>aside {
  width: 268px;
  padding: 12px 14px 10px;
  background: #202f34;
  color: #b7c9cc;
  font-size: var(--sidebar-item-font-size);
  line-height: 1.35;
}
body>main {
  margin-left: 268px;
}
body>aside .project-brand,
body>aside nav,
body>aside nav h4,
body>aside nav>button {
  width: 100%;
  max-width: 100%;
  margin-left: 0;
  margin-right: 0;
}
body>aside .project-brand {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 66px;
  margin: 0 0 12px;
  padding: 0 52px 0 0;
}
body>aside .project-brand-logo {
  display: block;
  width: 218px;
  max-width: 100%;
  height: auto;
  background: transparent;
}
body>aside nav {
  display: grid;
  gap: 1px;
}
body>aside nav h4 {
  min-height: 34px;
  margin: 8px 0 2px;
  padding: 8px 10px;
  background: #17262b;
  color: #fff;
  font-size: var(--sidebar-group-font-size);
  font-weight: 700;
  line-height: 1.25;
  text-transform: uppercase;
}
body>aside nav h4 span {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
body>aside nav h4 i {
  flex: 0 0 14px;
}
body>aside nav button {
  display: block;
  width: 100%;
  min-height: 33px;
  padding: 6px 8px;
  color: #b7c9cc;
  text-align: left;
  font-size: var(--sidebar-item-font-size);
  line-height: 1.35;
}
body>aside nav button.active,
body>aside nav button:hover {
  background: #344a50;
  color: #fff;
}
body>aside nav button.sidebar-subgroup {
  min-height: 33px;
  background: #182b30;
  color: #fff;
  font-weight: 700;
}
body>aside .sidebar-subitems button {
  padding-left: 18px;
}
@media(max-width:900px) {
  body>aside {
    width: min(82vw, 320px);
    padding: 12px 14px 10px;
  }
  body>main {
    margin-left: 0;
  }
  body>aside .project-brand {
    height: 58px;
  }
  body>aside .project-brand-logo {
    width: 210px;
  }
}

