  .diary-week-grid{padding:0 10px 10px}
  .diary-month-panel{margin:0 10px 10px}
  .diary-month-panel .diary-week b{padding:7px 2px}
  .diary-smart .diary-calendar>i{min-height:68px;padding:3px}
  .diary-smart .diary-calendar>i>small{width:19px;height:19px;font-size:9px}
  .diary-smart .diary-calendar .diary-entry-card{margin-top:2px;padding:3px;border-left-width:2px}
  .diary-smart .diary-calendar .diary-entry-top b{font-size:0;line-height:1}
  .diary-smart .diary-calendar .diary-entry-top b:after{content:"NKTC";font-size:9px}
}

