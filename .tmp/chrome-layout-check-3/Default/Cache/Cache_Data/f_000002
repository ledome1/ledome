.diary-smart .diary-calendar .diary-entry-card{gap:4px;margin-top:3px;padding:6px 7px;border-color:#c5dfdc;border-left-width:3px;background:#fff;font-size:10px;box-shadow:none}
.diary-smart .diary-calendar .diary-entry-top em,.diary-smart .diary-calendar .diary-entry-card small{display:none}
.diary-entry-alerts{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:4px}
