function diaryTaskSummary(tasks=[],fallback=""){
  const cleaned=tasks.map(task=>String(task||"").replace(/^\d+(\.\d+)*\s*/,"").replace(/\s+/g," ").trim()).filter(Boolean);
  const source=cleaned.length?cleaned:String(fallback||"").split(/[,;/]+/).map(item=>item.replace(/^HẠNG MỤC:\s*/i,"").trim()).filter(Boolean);
  if(!source.length)return "Chưa có task trong ngày";
  const summary=source.slice(0,4).map(task=>task.length>42?`${task.slice(0,39).trim()}...`:task).join("; ");
  return source.length>4?`${summary} +${source.length-4} task`:summary;
}
