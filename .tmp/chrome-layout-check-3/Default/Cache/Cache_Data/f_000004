function diaryEditableTable(headers,rows){return `<table class="stat-table diary-edit-table"><thead><tr>${headers.map(x=>`<th>${x}</th>`).join("")}</tr></thead><tbody>${rows.map(row=>`<tr>${row.map(cell=>`<td>${cell}</td>`).join("")}</tr>`).join("")}</tbody></table>`}
const diaryMaterialUnitOptions=["kg","g","tấn","bao","thùng","hộp","cái","bộ","cuộn","cây","tấm","viên","m","m2","m3","lít","chai","lon"];
function diaryWarehouseItems(){return Array.isArray(warehouseRows)?warehouseRows.map(row=>({code:String(row[0]||"").trim(),name:String(row[1]||"").trim(),unit:String(row[2]||"").trim()})).filter(item=>item.name):[]}
function diaryWarehouseItemOptions(){return [...new Set(diaryWarehouseItems().map(item=>item.name))]}
function diaryWarehouseUnitForItem(name){return diaryWarehouseItems().find(item=>item.name===name)?.unit||diaryMaterialUnitOptions[0]}
function diaryDeleteRowButton(kind){return `<button type="button" class="diary-row-delete" data-diary-delete-row="${kind}" title="Xóa dòng">×</button>`}
function diaryTaskMaterials(open){const warehouseOptions=["Kho văn phòng","Kho dự án"],itemOptions=diaryWarehouseItemOptions(),defaults=itemOptions.slice(0,2);if(!itemOptions.length)return `<div class="diary-task-table-scroll" data-diary-section="materials" ${open?"":"hidden"}><table class="stat-table diary-edit-table"><thead><tr><th>STT</th><th>Thiết bị Vật tư</th><th>Kho xuất</th><th>Thời gian xuất</th><th>Số lượng</th><th>Đơn vị</th><th></th></tr></thead><tbody><tr class="diary-empty-row"><td colspan="7">Chưa có vật tư trong danh sách Kho. <a data-view-link="warehouse">Mở danh sách Kho</a></td></tr></tbody></table></div>`;const rows=defaults.map((item,index)=>[String(index+1),diaryEditSelect(item,itemOptions),diaryEditSelect("Kho dự án",warehouseOptions),diaryEditInput("18:00",'type="time"'),diaryEditInput(index===0?"23":"45",'inputmode="decimal"'),diaryEditSelect(diaryWarehouseUnitForItem(item),diaryMaterialUnitOptions),diaryDeleteRowButton("materials")]);return `<div class="diary-task-table-scroll" data-diary-section="materials" ${open?"":"hidden"}>${diaryEditableTable(["STT","Thiết bị Vật tư","Kho xuất","Thời gian xuất","Số lượng","Đơn vị",""],rows)}</div>`}
function diaryTaskLabor(open){const rows=[["Ca sáng",diaryEditInput("7",'inputmode="numeric"'),diaryEditInput("07:00",'type="time"'),diaryEditInput("12:00",'type="time"')],["Ca chiều",diaryEditInput("14",'inputmode="numeric"'),diaryEditInput("13:00",'type="time"'),diaryEditInput("18:00",'type="time"')],["Tăng ca",diaryEditInput("",'inputmode="numeric"'),diaryEditInput("18:00",'type="time"'),diaryEditInput("21:00",'type="time"')]];return `<div class="diary-task-table-scroll diary-labor-compact" data-diary-section="labor" ${open?"":"hidden"}>${diaryEditableTable(["Ca","Số công nhân","Giờ vào làm","Giờ kết thúc"],rows)}</div>`}
const diaryStandardPresets={
  prepare:{title:"Chuẩn bị thi công",sources:["PDF Le Dome v3","TCVN 4085:2011"],prepare:["Khảo sát hiện trạng, tim trục, cao độ và phạm vi bàn giao trước khi thi công.","Che phủ sàn, đồ hiện trạng, thang máy và lối vận chuyển trước khi đưa vật tư vào.","Chốt tuyến đi lại, vị trí tập kết, nguồn điện/nước tạm và biện pháp an toàn."],execution:["Rào chắn khu vực nguy hiểm, biển cảnh báo rõ tại điểm phá dỡ hoặc tập kết.","Phân luồng nhân lực theo khu vực để không giao cắt với khu đã hoàn thiện.","Thu gom rác theo ca, không để vật tư chắn lối thoát hiểm hoặc cửa kỹ thuật."],acceptance:["Có ảnh hiện trạng trước/sau che phủ và biên bản bàn giao mặt bằng.","Không phát sinh trầy xước, bụi bẩn, hư hại tài sản hiện trạng.","Lối vận chuyển, điện tạm và khu tập kết đáp ứng yêu cầu an toàn."],risks:["Thi công khi chưa chốt cao độ/tim trục.","Che phủ thiếu tại góc cạnh, cửa, sàn gỗ, mặt đá hoặc thiết bị hiện trạng.","Để rác và vật tư cản trở lối thoát hiểm."]},
  rough:{title:"Xây trát, phần thô",sources:["PDF Le Dome v3","TCVN 4085:2011","TCVN 9377:2012"],prepare:["Kiểm tra tim trục, cao độ, kích thước ô chờ và vị trí hệ M&E trước khi xây trát.","Tưới ẩm bề mặt, vệ sinh bụi dầu và chuẩn bị vữa đúng mác/quy cách.","Xác nhận vật tư, lưới chống nứt, nẹp góc và điểm tiếp giáp với kết cấu cũ."],execution:["Xây đúng hàng, no mạch, liên kết chắc tại vị trí tiếp giáp cột/dầm/tường cũ.","Tô trát theo lớp, cán phẳng bằng thước, xử lý góc cạnh thẳng và sắc.","Dưỡng hộ bề mặt, tránh khô nhanh, va chạm hoặc tải sớm lên khu vừa thi công."],acceptance:["Mặt phẳng không rỗ, không bộp, không nứt chân chim vượt mức cho phép.","Kích thước, cao độ, độ vuông góc và vị trí ô chờ đúng bản vẽ.","Khu vực âm tường/đường ống đã nghiệm thu trước khi đóng kín."],risks:["Trát quá dày trong một lớp.","Không tạo nhám/tưới ẩm trước khi tô trên nền cũ.","Đóng kín đường ống khi chưa test áp hoặc chụp ảnh nghiệm thu."]},
  waterproof:{title:"Chống thấm",sources:["PDF Le Dome v3","TCVN 9377:2012"],prepare:["Vệ sinh nền, bo góc chân tường, xử lý cổ ống, phễu thu và khe nứt trước khi quét.","Đảm bảo nền đủ khô/ẩm theo hướng dẫn vật liệu, không đọng nước hoặc bụi bột.","Che chắn khu vực để tránh dẫm đạp trong thời gian vật liệu đóng rắn."],execution:["Quét đủ số lớp và định mức, lớp sau vuông góc hoặc phủ kín lớp trước.","Gia cường lưới/băng tại góc tường, cổ ống, khe tiếp giáp và chân cửa.","Bảo dưỡng đúng thời gian trước khi ngâm nước hoặc thi công lớp bảo vệ."],acceptance:["Test ngâm nước tối thiểu 24 giờ với khu vệ sinh, ban công hoặc khu ẩm ướt.","Không thấm, không rỗ kim, không bong tách tại cổ ống và chân tường.","Có ảnh từng lớp chống thấm, vị trí cổ ống và kết quả test nước."],risks:["Bỏ qua bo góc hoặc cổ ống.","Ốp lát ngay khi lớp chống thấm chưa đủ thời gian đóng rắn.","Không lập ảnh nghiệm thu trước khi cán/ốp lớp kế tiếp."]},
  mep:{title:"Điện nước, M&E",sources:["PDF Le Dome v3","TCVN 7447","TCVN 4519","TCVN 9206"],prepare:["Đối chiếu bản vẽ ổ cắm, công tắc, thiết bị, đường cấp thoát nước và cao độ hoàn thiện.","Kiểm tra chủng loại ống, dây, thiết bị bảo vệ, phụ kiện nối và nhãn mạch.","Định vị tuyến đi âm tường/sàn trước khi cắt đục, tránh giao cắt kết cấu."],execution:["Đi ống thẳng tuyến, cố định chắc, tách nguồn mạnh/yếu và dùng hộp nối đúng vị trí.","Test áp lực nước, test thoát nước, đo thông mạch/cách điện trước khi đóng kín.","Chụp ảnh toàn bộ tuyến âm, kích thước định vị từ mốc cố định để phục vụ bảo trì."],acceptance:["Không rò rỉ, không nghẹt, không đấu sai cực, sai mạch hoặc thiếu tiếp địa.","Thiết bị đúng cao độ, thẳng hàng, vận hành ổn định sau khi cấp nguồn/cấp nước.","Tủ điện, aptomat, nhãn mạch và sơ đồ hoàn công được cập nhật."],risks:["Đóng tường khi chưa test áp/test điện.","Để đầu nối âm tường không có hộp nối kiểm tra.","Không tách tuyến điện mạnh, điện nhẹ và ống nước nóng."]},
  drywall:{title:"Trần, vách thạch cao",sources:["PDF Le Dome v3","TCVN 8256"],prepare:["Kiểm tra cao độ trần, vị trí đèn, miệng gió, đầu báo, rèm và cửa thăm kỹ thuật.","Chốt chủng loại khung xương, tấm, phụ kiện treo, khoảng cách treo và vị trí gia cường.","Nghiệm thu M&E trên trần trước khi đóng tấm."],execution:["Lắp khung đúng khoảng cách, treo chắc, phẳng cao độ và có chống rung khi cần.","Bắt vít đúng bước, xử lý mép tấm, băng keo lưới và bột xử lý mối nối đầy đủ.","Chừa khe kỹ thuật, nắp thăm và gia cường vị trí treo thiết bị."],acceptance:["Mặt trần/vách phẳng, không võng, không nứt mối nối, không lộ vít.","Cao độ và vị trí lỗ khoét đúng bản vẽ, mép khoét sạch và chắc.","Có ảnh nghiệm thu khung xương trước khi đóng tấm."],risks:["Treo khung vào hệ M&E hoặc điểm neo không đủ lực.","Bỏ qua băng lưới mối nối.","Khoét lỗ thiết bị sau khi sơn hoàn thiện gây sứt mép."]},
  tile:{title:"Ốp lát, đá",sources:["PDF Le Dome v3","TCVN 9377:2012"],prepare:["Kiểm tra cao độ nền, độ dốc thoát nước, quy cách ron, tim lát và mẫu gạch/đá đã duyệt.","Ngâm hoặc xử lý mặt sau vật liệu theo khuyến cáo, vệ sinh nền và căn chỉnh layout.","Xác nhận vị trí cắt, nẹp, phào, cổ ống, phễu thu và điểm kết thúc vật liệu."],execution:["Trải keo/vữa đều, gõ ép đủ bám dính, kiểm soát ron thẳng và mặt phẳng liên tục.","Cắt cạnh gọn, dùng nẹp phù hợp tại góc ngoài, mép chuyển vật liệu và cạnh cửa.","Vệ sinh ron, bảo vệ bề mặt sau lát, không đi lại khi chưa đủ thời gian đóng rắn."],acceptance:["Không bộp rỗng, không lệch ron, không sứt cạnh, không đọng nước tại khu ướt.","Độ dốc về phễu thu đúng, mặt phẳng và cao độ chuyển tiếp đạt yêu cầu.","Có ảnh layout, điểm cắt và nghiệm thu trước khi che phủ bảo vệ."],risks:["Không kiểm tra độ dốc trước khi lát WC/ban công.","Dùng ron không đồng đều hoặc bám bẩn sau thi công.","Cắt gạch tại vị trí dễ thấy khi chưa được duyệt layout."]},
  paint:{title:"Sơn bả",sources:["PDF Le Dome v3","TCVN 9404:2012"],prepare:["Kiểm tra độ khô, độ phẳng, nứt chân chim và bề mặt sau trát/thạch cao.","Che chắn sàn, cửa, thiết bị, đèn, công tắc và các bề mặt đã hoàn thiện.","Chốt mã màu, mẫu sơn, hệ sơn lót/phủ và khu vực thử màu với CDT."],execution:["Bả đủ lớp, xả nhám sạch bụi, xử lý góc cạnh và mối nối trước khi sơn lót.","Sơn lót kín bề mặt, sơn phủ đủ số lớp, lăn đều tay theo cùng chiều hoàn thiện.","Giữ thông thoáng, tránh bụi, nước và va chạm trong thời gian sơn khô."],acceptance:["Màu đồng đều, không chảy sơn, không loang, không lộ vết vá hoặc vết con lăn.","Góc cạnh sắc, mép tiếp giáp sạch, không lem lên vật liệu khác.","Có ảnh màu mẫu và ảnh hoàn thiện sau khi tháo che chắn."],risks:["Sơn khi tường còn ẩm.","Không vệ sinh bụi sau xả nhám.","Dặm vá khác lô màu hoặc không sơn phủ lại toàn mảng."]},
  flooring:{title:"Sàn gỗ, sàn nhựa",sources:["PDF Le Dome v3"],prepare:["Kiểm tra độ phẳng, độ ẩm nền, cao độ hoàn thiện và khe hở cửa trước khi lắp.","Để vật liệu ổn định tại công trình theo khuyến cáo nhà sản xuất.","Chốt hướng lát, vị trí nẹp, phào chân tường và điểm chuyển vật liệu."],execution:["Lắp lớp lót đúng quy cách, giữ khe giãn nở, khóa hèm kín và tránh ép căng sát tường.","Cắt cạnh gọn tại khung cửa, chân tường, ống xuyên và vị trí nẹp kết thúc.","Bảo vệ bề mặt ngay sau thi công, hạn chế kéo lê vật nặng."],acceptance:["Mặt sàn phẳng, không phồng, không hở hèm, không kêu bất thường khi đi lại.","Nẹp, phào, điểm chuyển vật liệu chắc và thẳng hàng.","Không trầy xước, dính keo hoặc bẩn ron tại khu hoàn thiện."],risks:["Lắp khi nền còn ẩm hoặc chưa đủ phẳng.","Không chừa khe giãn nở.","Lắp phào/nẹp trước khi kiểm tra độ kín hèm."]},
  joinery:{title:"Gỗ nội thất",sources:["PDF Le Dome v3"],prepare:["Đối chiếu kích thước hiện trạng, bản vẽ shop, mẫu vật liệu, mã màu và phụ kiện đã duyệt.","Kiểm tra tường/sàn/trần, điểm cấp điện nước liên quan trước khi đưa đồ vào lắp.","Che phủ đường vận chuyển và khu vực đã hoàn thiện."],execution:["Lắp đặt theo trình tự, cân chỉnh thẳng, chắc, khe hở đều và không cấn thiết bị.","Bắt phụ kiện đúng vị trí, test bản lề, ray, tay nâng, khóa, đèn led và thiết bị tích hợp.","Bơm keo/chít khe gọn, không lem lên bề mặt hoàn thiện."],acceptance:["Kích thước, màu, vân, khe hở, độ phẳng và độ chắc đúng bản vẽ đã duyệt.","Cánh/tủ/ray hoạt động êm, không xệ, không cấn và không trầy xước.","Có ảnh bàn giao từng module và danh sách lỗi cần xử lý nếu có."],risks:["Không đo lại hiện trạng trước sản xuất/lắp đặt.","Lắp đồ khi khu vực còn ẩm bụi hoặc chưa hoàn thiện thô.","Không test phụ kiện trước khi bàn giao."]},
  envelope:{title:"Cửa, nhôm kính, sắt",sources:["PDF Le Dome v3","QCVN 16:2023/BXD"],prepare:["Kiểm tra kích thước ô chờ, cao độ nền, hướng mở, phụ kiện và mẫu vật liệu.","Chốt vị trí neo, gioăng, kính, khóa, tay nắm, sơn phủ hoặc xử lý chống gỉ.","Bảo vệ mép tường, sàn và bề mặt hoàn thiện quanh khu lắp đặt."],execution:["Lắp khung thẳng, vuông, neo chắc, bơm foam/silicone kín và không lem bẩn.","Căn chỉnh cánh, ray, bánh xe, khóa và gioăng để vận hành nhẹ, kín khít.","Xử lý sơn phủ, chống gỉ hoặc hoàn thiện mép cắt trước khi nghiệm thu."],acceptance:["Cửa/kính/khung không cong vênh, không xệ, không kẹt và không hở sáng bất thường.","Kính không xước, nứt; silicone đều, kín nước và sạch cạnh.","Phụ kiện hoạt động ổn định, khóa và chốt an toàn."],risks:["Neo khung vào nền/tường yếu hoặc chưa đủ khô.","Bơm silicone khi bề mặt còn bụi/ẩm.","Không bảo vệ kính và khung sau lắp đặt."]},
  technical:{title:"PCCC, điều hòa, smart home",sources:["QCVN 06:2022/BXD","TCVN 3890:2023","TCVN 5687:2024","TCVN 7447"],prepare:["Đối chiếu bản vẽ kỹ thuật, công suất, tải điện, vị trí thiết bị và đường ống/dây.","Kiểm tra vật tư đúng model, chứng chỉ, phụ kiện treo, bảo ôn và thiết bị bảo vệ.","Chốt kịch bản vận hành, vị trí điều khiển và điểm truy cập bảo trì."],execution:["Lắp đặt chắc, đúng hướng, đúng khoảng hở bảo trì và không cản lối thoát hiểm.","Test kín ống, test điện, test tín hiệu, test thoát nước ngưng và chạy thử tải.","Dán nhãn thiết bị, dây, mạch, đầu báo, đầu phun hoặc tuyến mạng/camera."],acceptance:["Thiết bị hoạt động đúng kịch bản, không rò nước, không quá nhiệt, không nhiễu tín hiệu.","Có biên bản chạy thử, thông số đo và ảnh hoàn công tuyến âm/trên trần.","Tài liệu hướng dẫn, bảo hành và sơ đồ đấu nối được bàn giao."],risks:["Lắp thiết bị khi chưa tính tải điện hoặc thoát nước ngưng.","Không chừa cửa thăm bảo trì.","Không test đồng bộ trước khi đóng trần/ốp hoàn thiện."]},
  defect:{title:"Defect, chấm vá, bàn giao",sources:["PDF Le Dome v3"],prepare:["Lập danh sách defect theo khu vực, ảnh, người phụ trách và thời hạn xử lý.","Phân loại lỗi theo sơn bả, gỗ, đá/gạch, điện nước, thiết bị và vệ sinh.","Che chắn lại khu vực đã đạt để không phát sinh lỗi mới trong lúc sửa."],execution:["Xử lý từng lỗi theo đúng hạng mục gốc, không dặm vá cục bộ gây lệch màu hoặc lệch phẳng.","Cập nhật trạng thái kèm ảnh trước/sau và ghi chú vật tư thay thế nếu có.","Dọn vệ sinh sau sửa, kiểm tra chéo trước khi mời CDT nghiệm thu."],acceptance:["Tất cả lỗi có ảnh sau xử lý và xác nhận đạt/không đạt rõ ràng.","Không phát sinh lỗi phụ do quá trình sửa chữa.","Hồ sơ bàn giao có checklist, ảnh hoàn thiện và biên bản xác nhận."],risks:["Sửa lỗi không theo danh sách kiểm soát.","Dặm sơn/vật liệu khác lô làm lệch màu.","Không kiểm tra lại sau vệ sinh cuối."]},
