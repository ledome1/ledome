function fileOpenType(file){const name=String(file?.name||file||"").toLowerCase(),category=file?.category||"";if(category==="image"||/\.(jpe?g|png|webp|gif|bmp)$/i.test(name))return "image";if(category==="video"||/\.(mp4|mov|webm|m4v|avi|mkv)$/i.test(name))return "video";if(/\.pdf$/i.test(name))return "pdf";if(/\.(txt|md|note|log|csv)$/i.test(name))return "text";if(/\.(doc|docx|xls|xlsx|ppt|pptx)$/i.test(name))return "office";return "file"}
